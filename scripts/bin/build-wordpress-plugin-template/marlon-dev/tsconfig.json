{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "sourceMap": true,
    "strict": true,
    "baseUrl": "./src/frontend",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": ["src/frontend/**/*"],
  "exclude": ["node_modules", "public"]
}
